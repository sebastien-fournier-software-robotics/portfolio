# Web3Forms: get your access key at https://web3forms.com/
# Copy this file to .env and set your key so the contact form can send emails.
REACT_APP_WEB3FORMS_ACCESS_KEY=your_access_key_here

# Optional: hCaptcha site key. Leave unset to use Web3Forms free plan key; set your own for paid plans.
# REACT_APP_HCAPTCHA_SITE_KEY=your_hcaptcha_site_key
